LM_STUDIO_BASE_URL=http://localhost:1234/v1
JARVIS_PREFERRED_PROVIDER_ORDER=ollama,lm-studio,nvidia,openai,anthropic
JARVIS_DEFAULT_LOCAL_CHAT_MODEL=llama3.2
JARVIS_DEFAULT_CODING_MODEL=deepseek-coder-v2
JARVIS_DEFAULT_RESEARCH_MODEL=llama3.2

# Cloud providers are disabled and blocked by privacy mode unless explicitly enabled.
JARVIS_ALLOW_CLOUD_MODELS=true
JARVIS_PRIVACY_MODE=true
