# Local providers work without API keys. Start either service and J.A.R.V.I.S. detects it.
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234/v1
JARVIS_PREFERRED_PROVIDER_ORDER=ollama,lm-studio,openai,anthropic
JARVIS_DEFAULT_LOCAL_CHAT_MODEL=llama3.2
JARVIS_DEFAULT_CODING_MODEL=deepseek-coder-v2
JARVIS_DEFAULT_RESEARCH_MODEL=llama3.2

# Cloud providers are disabled and blocked by privacy mode unless explicitly enabled.
JARVIS_ALLOW_CLOUD_MODELS=false
JARVIS_PRIVACY_MODE=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional browser-safe Supabase configuration.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
